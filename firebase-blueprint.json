{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "Represents an assigned ticket entry with a number between 0 and 400",
      "type": "object",
      "properties": {
        "ticketNumber": {
          "type": "integer",
          "description": "Unique assigned ticket number from 0 to 400"
        },
        "name": {
          "type": "string",
          "description": "Full name of the ticket holder"
        },
        "contact": {
          "type": "string",
          "description": "Contact identifier or social handle"
        },
        "assignedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the ticket was generated"
        },
        "drawn": {
          "type": "boolean",
          "description": "Whether this ticket has won a raffle prize"
        },
        "drawnAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this ticket was drawn as a winner"
        },
        "prizeTitle": {
          "type": "string",
          "description": "Title of the prize won"
        }
      },
      "required": ["ticketNumber", "name", "contact", "assignedAt", "drawn"]
    },
    "Prize": {
      "title": "Prize",
      "description": "Raffle prize category available for the event draws",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Raffle prize title"
        },
        "count": {
          "type": "integer",
          "description": "Initial stock count"
        },
        "remaining": {
          "type": "integer",
          "description": "Remaining stock count"
        },
        "cashValue": {
          "type": "number",
          "description": "Estimated cash valuation in Naira"
        }
      },
      "required": ["title", "count", "remaining", "cashValue"]
    }
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Raffle ticket entries"
    },
    "/prizes/{prizeId}": {
      "schema": "Prize",
      "description": "Available prizes registry"
    }
  }
}
