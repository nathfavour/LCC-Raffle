rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all rule as the Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidTicket(data) {
      return data.ticketNumber is int 
        && data.ticketNumber >= 0 
        && data.ticketNumber <= 400
        && data.name is string 
        && data.name.size() > 0 
        && data.name.size() <= 100
        && data.contact is string 
        && data.contact.size() > 0 
        && data.contact.size() <= 100
        && data.drawn is bool;
    }

    // Match tickets collection
    match /tickets/{ticketId} {
      allow read: if true; // Public lookup portal searches tickets
      allow create: if isSignedIn() && isValidId(ticketId) && isValidTicket(request.resource.data) 
        && request.resource.data.assignedAt == request.time;
      allow update: if isSignedIn() && isValidId(ticketId) && isValidTicket(request.resource.data);
      allow delete: if isSignedIn() && isValidId(ticketId);
    }

    // Match prizes collection
    match /prizes/{prizeId} {
      allow read: if true; // Anyone can display interactive prizes
      allow create, update: if isSignedIn() && isValidId(prizeId);
      allow delete: if isSignedIn() && isValidId(prizeId);
    }
  }
}
