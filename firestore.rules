rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.email == 'nathfavour02@gmail.com'
      );
    }

    // Checking if the verified user email exists in config/auth allowed_admins list or is the bootstrapped admin
    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'nathfavour02@gmail.com' || (
          exists(/databases/$(database)/documents/config/auth) &&
          request.auth.token.email in get(/databases/$(database)/documents/config/auth).data.allowed_admins
        )
      );
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['ticketNumber', 'name', 'contact', 'assignedAt', 'drawn']) &&
             data.keys().size() <= 8 &&
             data.ticketNumber is number &&
             data.ticketNumber >= 0 &&
             data.ticketNumber <= 400 &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() < 200 &&
             data.contact is string &&
             data.contact.size() > 0 &&
             data.contact.size() < 200 &&
             data.drawn is bool &&
             (!('prizeTitle' in data) || (data.prizeTitle is string && data.prizeTitle.size() < 200));
    }

    function isValidSpin(data) {
      return data.keys().hasAll(['timestamp', 'prizeTitle', 'winnerTicketNumber', 'winnerName', 'status']) &&
             data.keys().size() <= 8 &&
             data.timestamp is string &&
             data.prizeTitle is string &&
             data.winnerTicketNumber is number &&
             data.winnerName is string &&
             data.status is string;
    }

    // 2. Auth Config Documents
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Tickets Matching (Strict Bounded 0-400, deterministic structure)
    match /tickets/{ticketNumber} {
      allow read: if true;
      allow create: if isValidTicket(request.resource.data);
      allow update: if isAdmin() && isValidTicket(request.resource.data);
      allow delete: if isAdmin();
    }

    // 4. Spin History Ledger (Admins only)
    match /spins/{spinId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidSpin(request.resource.data);
      allow update: if isAdmin() && isValidSpin(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
