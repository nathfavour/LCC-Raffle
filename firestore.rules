rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Checking if the verified user email exists in config/auth allowed_admins list
    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email in get(/databases/$(database)/documents/config/auth).data.allowed_admins
      );
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['ticketNumber', 'name', 'contact', 'assignedAt', 'drawn']) &&
             data.keys().size() <= 7 &&
             data.ticketNumber is int &&
             data.ticketNumber >= 0 &&
             data.ticketNumber <= 400 &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() < 200 &&
             data.contact is string &&
             data.contact.size() > 0 &&
             data.contact.size() < 200 &&
             data.drawn is bool;
    }

    // 2. Auth Config Documents
    match /config/auth {
      allow read: if true;
      allow write: if isEmailVerified() && (
        resource == null || 
        request.auth.token.email in request.resource.data.allowed_admins ||
        request.auth.token.email in resource.data.allowed_admins
      );
    }

    // 3. Tickets Matching (Strict Bounded 0-400, deterministic structure)
    match /tickets/{ticketNumber} {
      allow read: if true;
      allow create: if isAdmin() && isValidTicket(request.resource.data);
      allow update: if isAdmin() && isValidTicket(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
